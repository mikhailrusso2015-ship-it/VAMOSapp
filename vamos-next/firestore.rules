rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      // Blindaje: El rol NO puede ser modificado después de la creación
      allow update: if isAuthenticated() && request.auth.uid == userId 
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
      allow delete: if false;
    }

    match /trips/{tripId} {
      allow read: if true;
      
      // SLA v2.1: El cliente debe enviar su rol para validación, evitando get() innecesarios si es posible
      // o manteniendo la validación de servidor para seguridad crítica pero optimizada.
      allow create: if isAuthenticated() && request.resource.data.role == 'driver';
      
      allow update, delete: if isAuthenticated() && (
        resource.data.driverId == request.auth.uid || 
        resource.data.userId == request.auth.uid
      );
    }
  }
}
